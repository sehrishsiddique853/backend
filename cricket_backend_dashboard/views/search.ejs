<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Search Player - Cricket Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .search-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }

        .search-section {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
            margin-bottom: 2rem;
        }

        .search-title {
            color: #2c3e50;
            margin-bottom: 1.5rem;
            text-align: center;
            font-size: 2rem;
        }

        .search-form {
            display: flex;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .search-input {
            flex: 1;
            padding: 1rem 1.5rem;
            border: 2px solid #ecf0f1;
            border-radius: 25px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

        .search-input:focus {
            outline: none;
            border-color: #3498db;
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);
        }

        .search-button {
            padding: 1rem 2rem;
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
            border: none;
            border-radius: 25px;
            font-size: 1rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .search-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(52, 152, 219, 0.3);
        }

        .search-button:active {
            transform: translateY(0);
        }

        .search-hint {
            text-align: center;
            color: #7f8c8d;
            font-size: 0.9rem;
            margin-top: 1rem;
        }

        .results-section {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
        }

        .results-title {
            color: #2c3e50;
            margin-bottom: 1.5rem;
            font-size: 1.5rem;
        }

        .players-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
        }

        .player-card {
            background: #f8f9fa;
            border-radius: 10px;
            padding: 1.5rem;
            transition: all 0.3s ease;
            border-left: 4px solid #3498db;
        }

        .player-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
            background: white;
        }

        .player-link {
            text-decoration: none;
            color: inherit;
            display: block;
        }

        .player-header {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .player-image {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #3498db;
        }

        .player-basic-info {
            flex: 1;
        }

        .player-name {
            font-size: 1.2rem;
            font-weight: bold;
            color: #2c3e50;
            margin-bottom: 0.3rem;
        }

        .player-team {
            color: #3498db;
            font-weight: 500;
        }

        .no-results {
            text-align: center;
            padding: 3rem;
            color: #7f8c8d;
        }

        .no-results-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }

        .error-message {
            background: rgba(231, 76, 60, 0.1);
            border: 1px solid #e74c3c;
            color: #c0392b;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            text-align: center;
        }

        .success-message {
            background: rgba(46, 204, 113, 0.1);
            border: 1px solid #27ae60;
            color: #229954;
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            text-align: center;
        }

        .search-stats {
            text-align: center;
            color: #7f8c8d;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }
    </style>
</head>
<body>
    <nav>
        <h1>Cricket Dashboard</h1>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/scores">Scores</a></li>
            <li><a href="/series">Series</a></li>
            <li><a href="/teams">Teams</a></li>
            <li><a href="/search">Search Player</a></li>
        </ul>
    </nav>

    <main class="search-container">
     <div class="search-section">
            <h2 class="search-title">Search Players</h2>
            
            <form method="POST" action="/search" class="search-form">
                <input 
                    type="text" 
                    name="searchQuery" 
                    class="search-input" 
                    placeholder="Enter player name (e.g., Kohli, Smith, Williamson...)" 
                    value="<%= searchQuery %>"
                    required
                >
                <button type="submit" class="search-button">Search</button>
            </form>
            
            <div class="search-hint">
                💡 Tip: You can search by full name or last name. Minimum 2 characters required.
            </div>
        </div>

        <% if (error && searched) { %>
            <div class="error-message">
                <%= error %>
            </div>
        <% } %>

        <% if (players.length > 0) { %>
            <div class="success-message">
                Found <%= players.length %> player(s) matching "<%= searchQuery %>"
            </div>
        <% } %>

      <% if (searched) { %>
            <div class="results-section">
                <h3 class="results-title">Search Results</h3>
                
                <% if (players.length > 0) { %>
                    <div class="search-stats">
                        Showing <%= players.length %> result(s) for "<%= searchQuery %>"
                    </div>
                    
                    <div class="players-grid">
                        <% players.forEach(player => { %>
                            <a href="/player/<%= player.id %>" class="player-link">
                                <div class="player-card">
                                    <div class="player-header">
                                        <% if (player.faceImageId) { %>
                                            <img 
                                                src="http://i.cricketcb.com/stats/img/faceImages/<%= player.faceImageId %>.jpg" 
                                                alt="<%= player.name %>"
                                                class="player-image"
                                                onerror="this.src='data:image/svg+xml;base64,'"
                                            >
                                        <% } else { %>
                                            <div class="player-image" style="background: #ecf0f1; display: flex; align-items: center; justify-content: center; color: #7f8c8d;">
                                                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                                    <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                                                </svg>
                                            </div>
                                        <% } %>
                                        
                                        <div class="player-basic-info">
                                            <div class="player-name"><%= player.name %></div>
                                            <div class="player-team"><%= player.teamName %></div>
                                        </div>
                                    </div>
                                    
                                    <div style="text-align: center; margin-top: 1rem;">
                                        <span style="background: #3498db; color: white; padding: 0.3rem 0.8rem; border-radius: 15px; font-size: 0.8rem;">
                                            View Profile →
                                        </span>
                                    </div>
                                </div>
                            </a>
                        <% }); %>
                    </div>
                <% } else if (searched && !error) { %>
                    <div class="no-results">
                        <div class="no-results-icon">🔍</div>
                        <h3>No Players Found</h3>
                        <p>No players found matching "<%= searchQuery %>"</p>
                        <p>Try searching with a different name or check the spelling.</p>
                    </div>
                <% } %>
            </div>
        <% } %>
    </main>

    <script>
       document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.querySelector('.search-input');
            if (searchInput) {
                searchInput.focus();
            }
        });

       document.querySelector('.search-input')?.addEventListener('input', function() {
            const errorMessage = document.querySelector('.error-message');
            if (errorMessage) {
                errorMessage.style.display = 'none';
            }
        });
    </script>
</body>
</html>