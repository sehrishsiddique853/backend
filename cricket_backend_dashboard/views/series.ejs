<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Series Info - Cricket Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    
</head>
<body>
    <nav>
        <h1>Cricket Dashboard</h1>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/scores">Scores</a></li>
            <li><a href="/series">Series</a></li>
            <li><a href="/teams">Teams</a></li>
            <li><a href="/search">Search Player</a></li>
        </ul>
    </nav>

    <main class="series-container">
        <h2>International Cricket Series</h2>

        <% if (error) { %>
            <div class="no-series">
                <h3>Error Loading Series</h3>
                <p><%= error %></p>
            </div>
        <% } else if (seriesByMonth.length > 0) { %>
            <% seriesByMonth.forEach(monthGroup => { %>
                <div class="month-section">
                    <h3 class="month-title">
                        <%= monthGroup.date %>
                        <span class="series-count">(<%= monthGroup.series ? monthGroup.series.length : 0 %> series)</span>
                    </h3>
                    
                    <% if (monthGroup.series && monthGroup.series.length > 0) { %>
                        <div class="series-grid">
                            <% monthGroup.series.forEach(series => { %>
                                <div class="series-card">
                                    <div class="series-type">International</div>
                                    <h4 class="series-name"><%= series.name %></h4>
                                    
                                    <div class="series-details">
                                        <div class="detail-item">
                                            <span class="detail-label">Series ID:</span>
                                            <span class="detail-value">#<%= series.id %></span>
                                        </div>
                                        
                                        <div class="detail-item">
                                            <span class="detail-label">Start Date:</span>
                                            <span class="detail-value">
                                                <%= new Date(parseInt(series.startDt)).toLocaleDateString() %>
                                            </span>
                                        </div>
                                        
                                        <div class="detail-item">
                                            <span class="detail-label">End Date:</span>
                                            <span class="detail-value">
                                                <%= new Date(parseInt(series.endDt)).toLocaleDateString() %>
                                            </span>
                                        </div>
                                        
                                        <div class="detail-item">
                                            <span class="detail-label">Duration:</span>
                                            <span class="detail-value">
                                                <% 
                                                    const start = new Date(parseInt(series.startDt));
                                                    const end = new Date(parseInt(series.endDt));
                                                    const diffTime = Math.abs(end - start);
                                                    const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
                                                %>
                                                <%= diffDays %> days
                                            </span>
                                        </div>
                                    </div>

                                    <div class="date-range">
                                        <%= new Date(parseInt(series.startDt)).toLocaleDateString() %> - 
                                        <%= new Date(parseInt(series.endDt)).toLocaleDateString() %>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="no-series">
                            <p>No series scheduled for this month.</p>
                        </div>
                    <% } %>
                </div>
            <% }); %>
        <% } else { %>
            <div class="no-series">
                <h3>No Series Found</h3>
                <p>There are currently no international series scheduled.</p>
            </div>
        <% } %>
    </main>
</body>
</html>