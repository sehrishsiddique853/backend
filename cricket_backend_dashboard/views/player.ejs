<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= player ? player.name : 'Player Not Found' %> - Cricket Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .player-container {
            max-width: 1000px;
            margin: 0 auto;
            padding: 20px;
        }

        .player-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.1);
        }

        .player-header {
            display: flex;
            align-items: center;
            gap: 2rem;
            margin-bottom: 2rem;
            padding-bottom: 1.5rem;
            border-bottom: 2px solid #ecf0f1;
        }

        .player-image {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 4px solid #3498db;
        }

        .player-info {
            flex: 1;
        }

        .player-name {
            font-size: 2.5rem;
            color: #2c3e50;
            margin-bottom: 0.5rem;
        }

        .player-nickname {
            font-size: 1.5rem;
            color: #7f8c8d;
            font-style: italic;
            margin-bottom: 1rem;
        }

        .player-team {
            font-size: 1.3rem;
            color: #3498db;
            font-weight: bold;
            margin-bottom: 0.5rem;
        }

        .player-role {
            display: inline-block;
            background: #e74c3c;
            color: white;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: bold;
            text-transform: uppercase;
        }

        .player-details-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
            margin: 2rem 0;
        }

        .detail-card {
            background: #f8f9fa;
            padding: 1.5rem;
            border-radius: 10px;
            border-left: 4px solid #3498db;
        }

        .detail-label {
            font-size: 0.9rem;
            color: #7f8c8d;
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            font-weight: bold;
        }

        .detail-value {
            font-size: 1.1rem;
            color: #2c3e50;
            font-weight: 600;
        }

        .bio-section {
            margin: 2rem 0;
            padding: 1.5rem;
            background: #f8f9fa;
            border-radius: 10px;
        }

        .bio-title {
            font-size: 1.3rem;
            color: #2c3e50;
            margin-bottom: 1rem;
            padding-bottom: 0.5rem;
            border-bottom: 2px solid #3498db;
        }

        .bio-content {
            line-height: 1.6;
            color: #555;
        }

        .rankings-section {
            margin: 2rem 0;
        }

        .rankings-title {
            font-size: 1.3rem;
            color: #2c3e50;
            margin-bottom: 1rem;
        }

        .rankings-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .ranking-card {
            background: #2c3e50;
            color: white;
            padding: 1.5rem;
            border-radius: 10px;
            text-align: center;
        }

        .ranking-type {
            font-size: 0.9rem;
            opacity: 0.8;
            margin-bottom: 0.5rem;
        }

        .ranking-value {
            font-size: 1.5rem;
            font-weight: bold;
        }

        .back-link {
            display: inline-block;
            margin-top: 2rem;
            padding: 0.8rem 1.5rem;
            background: #3498db;
            color: white;
            text-decoration: none;
            border-radius: 25px;
            transition: all 0.3s ease;
        }

        .back-link:hover {
            background: #2980b9;
            transform: translateY(-2px);
        }

        .teams-list {
            margin-top: 0.5rem;
            font-size: 0.9rem;
            color: #7f8c8d;
        }
    </style>
</head>
<body>
    <nav>
        <h1>Cricket Dashboard</h1>
        <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/scores">Scores</a></li>
            <li><a href="/series">Series</a></li>
            <li><a href="/teams">Teams</a></li>
            <li><a href="/search">Search Player</a></li>
        </ul>
    </nav>

    <main class="player-container">
        <% if (error && !player) { %>
            <div class="player-card">
                <h3>Player Not Found</h3>
                <p><%= error %></p>
                <a href="/teams" class="back-link">Back to Teams</a>
            </div>
        <% } else if (player) { %>
            <div class="player-card">
                <div class="player-header">
                    <% if (player.image) { %>
                        <img src="<%= player.image %>" alt="<%= player.name %>" class="player-image" onerror="this.style.display='none'">
                    <% } %>
                    <div class="player-info">
                        <h1 class="player-name"><%= player.name %></h1>
                        <% if (player.nickName) { %>
                            <div class="player-nickname">"<%= player.nickName %>"</div>
                        <% } %>
                        <div class="player-team"><%= player.intlTeam %></div>
                        <div class="player-role"><%= player.role %></div>
                    </div>
                </div>

                <!-- Basic Details Grid -->
                <div class="player-details-grid">
                    <% if (player.bat) { %>
                        <div class="detail-card">
                            <div class="detail-label">Batting Style</div>
                            <div class="detail-value"><%= player.bat %></div>
                        </div>
                    <% } %>

                    <% if (player.bowl && player.bowl !== 'Right-arm offbreak') { %>
                        <div class="detail-card">
                            <div class="detail-label">Bowling Style</div>
                            <div class="detail-value"><%= player.bowl %></div>
                        </div>
                    <% } %>

                    <% if (player.DoB) { %>
                        <div class="detail-card">
                            <div class="detail-label">Date of Birth</div>
                            <div class="detail-value"><%= player.DoB %></div>
                        </div>
                    <% } %>

                    <% if (player.birthPlace) { %>
                        <div class="detail-card">
                            <div class="detail-label">Birth Place</div>
                            <div class="detail-value"><%= player.birthPlace %></div>
                        </div>
                    <% } %>

                    <% if (player.height) { %>
                        <div class="detail-card">
                            <div class="detail-label">Height</div>
                            <div class="detail-value"><%= player.height %></div>
                        </div>
                    <% } %>

                    <% if (player.teams) { %>
                        <div class="detail-card">
                            <div class="detail-label">Teams Played For</div>
                            <div class="detail-value">
                                <%= player.intlTeam %>
                                <div class="teams-list"><%= player.teams %></div>
                            </div>
                        </div>
                    <% } %>
                </div>

                <% if (player.rankings) { %>
                    <div class="rankings-section">
                        <h3 class="rankings-title">ICC Rankings</h3>
                        <div class="rankings-grid">
                            <% if (player.rankings.bat && player.rankings.bat[0]) { %>
                                <div class="ranking-card">
                                    <div class="ranking-type">Test Batting</div>
                                    <div class="ranking-value">
                                        <% if (player.rankings.bat[0].testRank && player.rankings.bat[0].testRank !== '0') { %>
                                            #<%= player.rankings.bat[0].testRank %>
                                        <% } else { %>
                                            N/A
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>

                            <% if (player.rankings.bat && player.rankings.bat[0]) { %>
                                <div class="ranking-card">
                                    <div class="ranking-type">Best ODI Rank</div>
                                    <div class="ranking-value">
                                        <% if (player.rankings.bat[0].odiBestRank && player.rankings.bat[0].odiBestRank !== '0') { %>
                                            #<%= player.rankings.bat[0].odiBestRank %>
                                        <% } else { %>
                                            N/A
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>

                            <% if (player.rankings.bat && player.rankings.bat[0]) { %>
                                <div class="ranking-card">
                                    <div class="ranking-type">Best T20 Rank</div>
                                    <div class="ranking-value">
                                        <% if (player.rankings.bat[0].t20BestRank && player.rankings.bat[0].t20BestRank !== '0') { %>
                                            #<%= player.rankings.bat[0].t20BestRank %>
                                        <% } else { %>
                                            N/A
                                        <% } %>
                                    </div>
                                </div>
                            <% } %>
                        </div>
                    </div>
                <% } %>

                <% if (player.bio) { %>
                    <div class="bio-section">
                        <h3 class="bio-title">Player Biography</h3>
                        <div class="bio-content"><%- player.bio %></div>
                    </div>
                <% } %>

               <% if (error) { %>
                    <div style="background: #fff3cd; color: #856404; padding: 1rem; border-radius: 5px; margin: 1rem 0;">
                        <strong>Note:</strong> <%= error %>
                    </div>
                <% } %>

                <a href="/teams" class="back-link">Back to Teams</a>
            </div>
        <% } %>
    </main>
</body>
</html>